# Salesforce auth for the Next.js server route.
# Use either a logged-in local `sf` CLI with SF_TARGET_ORG,
# or set SF_ACCESS_TOKEN + SF_INSTANCE_URL directly.

AUTH_SECRET=
AUTH_SLACK_ID=
AUTH_SLACK_SECRET=

SF_TARGET_ORG=
SF_ACCESS_TOKEN=
SF_INSTANCE_URL=
SF_API_VERSION=v66.0
SF_REVENUE_CACHE_TTL_MS=300000

# Vercel Postgres — auto-set when you link a Vercel Postgres store.
POSTGRES_URL=

# Vercel Blob — auto-set when you link a Vercel Blob store.
BLOB_READ_WRITE_TOKEN=
